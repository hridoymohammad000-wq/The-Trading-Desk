# Leave blank for same-origin /api, which is used by the Windows one-click launcher.
VITE_DSE_BACKEND_URL=

DSE_STORAGE_MODE=sqlite
DSE_STORAGE_PATH=./storage
DSE_DATABASE_PATH=./storage/dse_swing_v1.sqlite3

# Supabase / Postgres mode
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=
DATABASE_URL=

# Optional alternate CSV source for automatic backfill/daily refresh when the official
# DSE archive is unreachable. CSV must include SYMBOL,DATE/TRADE_DATE,OPEN,HIGH,LOW,CLOSE,VOLUME.
DSE_ALT_SOURCE_URL=
DSE_ALT_SOURCE_NAME=ALT_CSV_SOURCE
